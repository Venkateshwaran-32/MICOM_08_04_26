from pathlib import Path
import argparse
import cobra


PROJECT_ROOT = Path(__file__).resolve().parents[1]
MODELS_DIR = PROJECT_ROOT / "Models" / "vmh_agora_sbml"


def parse_args():
    parser = argparse.ArgumentParser(
        description="Basic SBML EDA for AGORA models."
    )
    parser.add_argument(
        "--model",
        help="Model filename or partial name, e.g. Alistipes_shahii or Alistipes_shahii_WAL_8301_AGORA1.03.xml",
    )
    parser.add_argument(
        "--reaction",
        help="Optional reaction ID to inspect inside the selected model.",
    )
    parser.add_argument(
        "--metabolite",
        help="Optional metabolite ID to inspect inside the selected model.",
    )
    parser.add_argument(
        "--list-models",
        action="store_true",
        help="List available SBML files and exit.",
    )
    return parser.parse_args()


def list_models():
    files = sorted(MODELS_DIR.glob("*.xml"))
    print(f"Models found: {len(files)}")
    for fp in files:
        print(fp.name)


def find_model(query: str) -> Path:
    files = sorted(MODELS_DIR.glob("*.xml"))
    exact = [fp for fp in files if fp.name == query]
    if exact:
        return exact[0]

    partial = [fp for fp in files if query.lower() in fp.stem.lower()]
    if len(partial) == 1:
        return partial[0]
    if not partial:
        raise SystemExit(f"No model matched: {query}")

    print("Multiple models matched. Be more specific:")
    for fp in partial:
        print(fp.name)
    raise SystemExit(1)


def print_model_summary(model):
    print("MODEL")
    print("id:", model.id)
    print("name:", model.name)
    print("objective:", model.objective.expression)
    print("reactions:", len(model.reactions))
    print("metabolites:", len(model.metabolites))
    print("genes:", len(model.genes))

    print("\nFIRST 10 REACTIONS")
    for rxn in model.reactions[:10]:
        print(f"{rxn.id}: {rxn.reaction}")

    print("\nFIRST 10 METABOLITES")
    for met in model.metabolites[:10]:
        print(f"{met.id}: {met.name} [{met.compartment}]")


def print_reaction(model, reaction_id: str):
    rxn = model.reactions.get_by_id(reaction_id)
    print("\nREACTION DETAIL")
    print("id:", rxn.id)
    print("name:", rxn.name)
    print("equation:", rxn.reaction)
    print("bounds:", rxn.lower_bound, rxn.upper_bound)
    print("metabolites:")
    for met, coeff in rxn.metabolites.items():
        print(f"  {met.id}: {coeff}")


def print_metabolite(model, metabolite_id: str):
    met = model.metabolites.get_by_id(metabolite_id)
    print("\nMETABOLITE DETAIL")
    print("id:", met.id)
    print("name:", met.name)
    print("compartment:", met.compartment)
    print("formula:", met.formula)
    print("charge:", met.charge)
    print("used in reactions:", len(met.reactions))
    for rxn in sorted(met.reactions, key=lambda x: x.id)[:20]:
        print(f"  {rxn.id}: {rxn.reaction}")


def main():
    args = parse_args()

    if args.list_models:
        list_models()
        return

    if not args.model:
        print("Pass --list-models or choose a model with --model")
        return

    model_path = find_model(args.model)
    print("Loading:", model_path.name)
    model = cobra.io.read_sbml_model(str(model_path))

    print_model_summary(model)

    if args.reaction:
        print_reaction(model, args.reaction)

    if args.metabolite:
        print_metabolite(model, args.metabolite)


if __name__ == "__main__":
    main()
